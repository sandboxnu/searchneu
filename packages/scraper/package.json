{
  "name": "@sneu/scraper",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "test": "node --test --import tsx ./**/*.test.ts"
  },
  "exports": {
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./events": {
      "types": "./dist/events.d.ts",
      "default": "./dist/events.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./generate": {
      "types": "./dist/generate/main.d.ts",
      "default": "./dist/generate/main.js"
    },
    "./upload": {
      "types": "./dist/upload/main.d.ts",
      "default": "./dist/upload/main.js"
    },
    "./update": {
      "types": "./dist/update/main.d.ts",
      "default": "./dist/update/main.js"
    },
    "./notifs": {
      "types": "./dist/update/notifs.d.ts",
      "default": "./dist/update/notifs.js"
    },
    "./generate/sections": {
      "types": "./dist/generate/steps/sections.d.ts",
      "default": "./dist/generate/steps/sections.js"
    },
    "./generate/marshall": {
      "types": "./dist/generate/marshall.d.ts",
      "default": "./dist/generate/marshall.js"
    },
    "./schemas/banner-cache": {
      "types": "./dist/schemas/scraper/banner-cache.d.ts",
      "default": "./dist/schemas/scraper/banner-cache.js"
    },
    "./static-config": {
      "types": "./dist/schemas/scraper/static-config.d.ts",
      "default": "./dist/schemas/scraper/static-config.js"
    }
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "html-entities": "^2.6.0",
    "node-html-parser": "^7.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@sneu/db": "workspace:*",
    "@sneu/eslint-config": "workspace:*",
    "@sneu/tsconfig": "workspace:*",
    "@types/he": "^1.2.3",
    "@types/node": "^25.6.0",
    "eslint": "^9.39.4",
    "nock": "^14.0.13",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}

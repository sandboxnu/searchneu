{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    "group:monorepos",
    "group:recommended"
  ],
  "schedule": ["* 0-4 1,15 * *"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "packageRules": [
    {
      "description": "Group all non-frozen dependencies into a single PR",
      "matchPackageNames": ["*"],
      "groupName": "all dependencies",
      "automerge": true
    },
    {
      "description": "Freeze eslint and @eslint/js at v9 — v10 is broken",
      "matchPackageNames": ["eslint", "@eslint/js"],
      "allowedVersions": "<10.0.0"
    },
    {
      "description": "Freeze paradedb docker image",
      "matchPackageNames": ["paradedb/paradedb"],
      "enabled": false
    }
  ]
}
